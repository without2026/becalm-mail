<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Becalm — 일에 몰두하세요. 정리는 내일 아침에 도착합니다.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&family=Playfair+Display:ital,wght@0,700;1,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #FAFAF8;
            --bg-card: #FFFFFF;
            --bg-dark: #111111;
            --bg-newsletter: #F5F3EE;
            --text-primary: #1A1A1A;
            --text-secondary: #5C5C5C;
            --text-muted: #999999;
            --text-on-dark: #F0EDE6;
            --accent: #E8590C;
            --accent-soft: #FFF0E8;
            --border: #E8E6E0;
            --border-light: #F0EDE6;
            --green-dot: #22C55E;
            --blue-tag: #3B82F6;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.04);
            --shadow-md: 0 4px 20px rgba(0,0,0,0.06);
            --shadow-lg: 0 12px 40px rgba(0,0,0,0.08);
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 20px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Noto Sans KR', -apple-system, sans-serif;
            color: var(--text-primary);
            background: var(--bg-primary);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        /* ── NAV ── */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 100;
            background: rgba(250, 250, 248, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-light);
            transition: all 0.3s ease;
        }

        .nav-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 32px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            font-weight: 700;
            font-size: 1.15rem;
            letter-spacing: -0.5px;
            color: var(--text-primary);
        }

        .nav-cta {
            background: var(--bg-dark);
            color: #fff;
            padding: 10px 22px;
            border-radius: 100px;
            font-size: 0.85rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.25s ease;
            letter-spacing: -0.2px;
        }

        .nav-cta:hover {
            background: #333;
            transform: translateY(-1px);
        }

        /* ── HERO ── */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 120px 32px 80px;
        }

        .hero-grid {
            max-width: 1100px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
            align-items: center;
        }

        .hero-text {
            animation: fadeInUp 0.8s ease forwards;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent-soft);
            color: var(--accent);
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 0.78rem;
            font-weight: 600;
            margin-bottom: 28px;
            letter-spacing: -0.2px;
        }

        .hero-badge::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--accent);
            animation: pulse 2s ease infinite;
        }

        .hero h1 {
            font-size: clamp(2.2rem, 4vw, 3.2rem);
            font-weight: 900;
            line-height: 1.25;
            letter-spacing: -1.5px;
            margin-bottom: 20px;
            color: var(--text-primary);
            word-break: keep-all;
        }

        .hero h1 em {
            font-style: normal;
            color: var(--accent);
        }

        .hero-desc {
            font-size: 1.08rem;
            color: var(--text-secondary);
            line-height: 1.8;
            margin-bottom: 36px;
            max-width: 460px;
            word-break: keep-all;
        }

        .hero-actions {
            display: flex;
            gap: 14px;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-dark);
            color: #fff;
            padding: 16px 32px;
            border-radius: 100px;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            letter-spacing: -0.3px;
        }

        .btn-primary:hover {
            background: #333;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

        .btn-primary svg {
            transition: transform 0.2s ease;
        }

        .btn-primary:hover svg {
            transform: translateX(3px);
        }

        .btn-ghost {
            color: var(--text-secondary);
            font-size: 0.88rem;
            text-decoration: none;
            padding: 8px 4px;
            border-bottom: 1px solid var(--border);
            transition: all 0.2s;
        }

        .btn-ghost:hover {
            color: var(--text-primary);
            border-color: var(--text-primary);
        }

        .hero-stats {
            display: flex;
            gap: 32px;
            margin-top: 40px;
            padding-top: 28px;
            border-top: 1px solid var(--border);
        }

        .hero-stat-num {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            color: var(--text-primary);
        }

        .hero-stat-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* ── NEWSLETTER PREVIEW (hero right) ── */
        .hero-visual {
            animation: fadeInUp 0.8s 0.2s ease forwards;
            opacity: 0;
        }

        .newsletter-preview {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg), 0 0 0 1px var(--border-light);
            overflow: hidden;
            transform: perspective(1200px) rotateY(-3deg) rotateX(2deg);
            transition: transform 0.5s ease;
        }

        .newsletter-preview:hover {
            transform: perspective(1200px) rotateY(0deg) rotateX(0deg);
        }

        .nl-topbar {
            background: #F7F5F0;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid var(--border-light);
        }

        .nl-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .nl-dot-r { background: #FE5F57; }
        .nl-dot-y { background: #FEBC2E; }
        .nl-dot-g { background: #28C840; }

        .nl-topbar-text {
            margin-left: 8px;
            font-size: 0.72rem;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
        }

        .nl-header {
            padding: 24px 28px 16px;
            border-bottom: 1px solid var(--border-light);
        }

        .nl-from {
            font-size: 0.72rem;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .nl-subject {
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 4px;
        }

        .nl-date {
            font-size: 0.72rem;
            color: var(--text-muted);
        }

        .nl-body {
            padding: 24px 28px;
        }

        .nl-greeting {
            font-size: 0.88rem;
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .nl-section-title {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 12px;
        }

        .nl-agenda-item {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            padding: 10px 0;
            border-bottom: 1px solid var(--border-light);
        }

        .nl-agenda-item:last-child {
            border-bottom: none;
        }

        .nl-time {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: var(--text-muted);
            min-width: 48px;
            padding-top: 2px;
        }

        .nl-agenda-content {
            flex: 1;
        }

        .nl-agenda-title {
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: -0.3px;
            margin-bottom: 3px;
        }

        .nl-agenda-desc {
            font-size: 0.72rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .nl-tag {
            display: inline-block;
            font-size: 0.62rem;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 100px;
            margin-top: 6px;
        }

        .nl-tag-decision {
            background: #EEF2FF;
            color: #4F46E5;
        }

        .nl-tag-research {
            background: #F0FDF4;
            color: #16A34A;
        }

        .nl-tag-followup {
            background: #FFF7ED;
            color: var(--accent);
        }

        .nl-divider {
            height: 1px;
            background: var(--border-light);
            margin: 20px 0;
        }

        .nl-reminder {
            background: #FFFBEB;
            border-left: 3px solid #F59E0B;
            padding: 12px 16px;
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            margin-top: 16px;
        }

        .nl-reminder-title {
            font-size: 0.72rem;
            font-weight: 700;
            color: #B45309;
            margin-bottom: 4px;
        }

        .nl-reminder-text {
            font-size: 0.72rem;
            color: #92400E;
            line-height: 1.5;
        }

        .nl-workflow-placeholder {
            background: var(--bg-newsletter);
            border-radius: var(--radius-sm);
            padding: 20px;
            margin-top: 16px;
            text-align: center;
        }

        .nl-workflow-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }

        .nl-workflow-nodes {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }

        .nl-node {
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 0.68rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-align: center;
            line-height: 1.4;
            flex: 1;
            min-width: 0;
        }

        .nl-node-active {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--accent-soft);
        }

        .nl-arrow {
            color: var(--text-muted);
            font-size: 0.7rem;
        }

        /* ── BEFORE/AFTER ── */
        .before-after {
            padding: 100px 32px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .section-label {
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 16px;
        }

        .section-title {
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            font-weight: 800;
            letter-spacing: -1px;
            line-height: 1.3;
            margin-bottom: 16px;
            word-break: keep-all;
        }

        .section-title em {
            font-style: normal;
            color: var(--accent);
        }

        .section-desc {
            font-size: 1rem;
            color: var(--text-secondary);
            max-width: 580px;
            margin-bottom: 48px;
        }

        .ba-grid {
            display: grid;
            grid-template-columns: 1fr 48px 1fr;
            gap: 0;
            align-items: stretch;
        }

        .ba-card {
            padding: 40px 36px;
            border-radius: var(--radius-lg);
            position: relative;
        }

        .ba-before {
            background: #F5F0F0;
            border: 1px solid #E8E0E0;
        }

        .ba-after {
            background: #F0F5EE;
            border: 1px solid #D8E8D0;
        }

        .ba-arrow {
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--text-muted);
        }

        .ba-card-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 20px;
        }

        .ba-before .ba-card-label { color: #C0392B; }
        .ba-after .ba-card-label { color: #27AE60; }

        .ba-item {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            padding: 14px 0;
            border-bottom: 1px solid rgba(0,0,0,0.06);
        }

        .ba-item:last-child { border-bottom: none; }

        .ba-icon {
            font-size: 1.1rem;
            flex-shrink: 0;
            width: 28px;
            text-align: center;
            padding-top: 1px;
        }

        .ba-item-text {
            font-size: 0.88rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .ba-item-text strong {
            color: var(--text-primary);
            font-weight: 600;
        }

        /* ── HOW IT WORKS ── */
        .how-section {
            padding: 100px 32px;
            background: var(--bg-dark);
            color: var(--text-on-dark);
        }

        .how-inner {
            max-width: 1100px;
            margin: 0 auto;
        }

        .how-section .section-label {
            color: rgba(232, 89, 12, 0.8);
        }

        .how-section .section-title {
            color: #fff;
        }

        .how-section .section-desc {
            color: rgba(255,255,255,0.5);
        }

        .how-steps {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            margin-top: 48px;
        }

        .how-step {
            position: relative;
            padding: 36px 28px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-md);
            transition: all 0.3s ease;
        }

        .how-step:hover {
            background: rgba(255,255,255,0.07);
            border-color: rgba(255,255,255,0.12);
            transform: translateY(-4px);
        }

        .how-step-num {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 700;
            color: rgba(232, 89, 12, 0.25);
            line-height: 1;
            margin-bottom: 16px;
        }

        .how-step-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #fff;
            letter-spacing: -0.3px;
        }

        .how-step-desc {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.5);
            line-height: 1.7;
        }

        .how-step-time {
            display: inline-block;
            margin-top: 16px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: var(--accent);
            background: rgba(232, 89, 12, 0.1);
            padding: 4px 10px;
            border-radius: 100px;
        }

        /* ── PERSONAS ── */
        .persona-section {
            padding: 100px 32px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .persona-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 48px;
        }

        .persona-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 32px 28px;
            transition: all 0.3s ease;
        }

        .persona-card:hover {
            border-color: var(--accent);
            box-shadow: var(--shadow-md);
            transform: translateY(-4px);
        }

        .persona-role {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 14px;
        }

        .persona-pain {
            font-size: 1rem;
            font-weight: 700;
            line-height: 1.5;
            letter-spacing: -0.3px;
            margin-bottom: 12px;
        }

        .persona-detail {
            font-size: 0.83rem;
            color: var(--text-secondary);
            line-height: 1.7;
        }

        /* ── SOCIAL PROOF ── */
        .proof-section {
            padding: 80px 32px;
            background: var(--bg-newsletter);
        }

        .proof-inner {
            max-width: 1100px;
            margin: 0 auto;
        }

        .proof-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            margin-top: 48px;
        }

        .proof-card {
            background: var(--bg-card);
            border-radius: var(--radius-md);
            padding: 32px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-light);
        }

        .proof-quote {
            font-size: 0.95rem;
            line-height: 1.8;
            color: var(--text-primary);
            margin-bottom: 20px;
            font-weight: 400;
            position: relative;
            padding-left: 20px;
            border-left: 3px solid var(--accent);
        }

        .proof-author {
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        .proof-author strong {
            color: var(--text-secondary);
            font-weight: 600;
        }

        /* ── PRICING ── */
        .pricing-section {
            padding: 100px 32px;
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
        }

        .pricing-card {
            background: var(--bg-card);
            border: 2px solid var(--bg-dark);
            border-radius: var(--radius-lg);
            padding: 48px 40px;
            margin-top: 48px;
            position: relative;
            overflow: hidden;
        }

        .pricing-popular {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            background: var(--bg-dark);
            color: #fff;
            padding: 8px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .pricing-top {
            padding-top: 20px;
        }

        .pricing-seats {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--accent-soft);
            color: var(--accent);
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 24px;
        }

        .pricing-price {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 4px;
            margin-bottom: 8px;
        }

        .pricing-currency {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-secondary);
        }

        .pricing-amount {
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: -2px;
            line-height: 1;
        }

        .pricing-period {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .pricing-original {
            font-size: 0.88rem;
            color: var(--text-muted);
            text-decoration: line-through;
            margin-bottom: 24px;
        }

        .pricing-desc {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 32px;
        }

        .pricing-features {
            text-align: left;
            max-width: 400px;
            margin: 0 auto 36px;
        }

        .pricing-feature {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            padding: 10px 0;
            font-size: 0.88rem;
            color: var(--text-secondary);
        }

        .pricing-check {
            color: var(--green-dot);
            font-weight: 700;
            flex-shrink: 0;
        }

        .btn-pricing {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent);
            color: #fff;
            padding: 18px 48px;
            border-radius: 100px;
            font-size: 1.05rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            letter-spacing: -0.3px;
        }

        .btn-pricing:hover {
            background: #D14B00;
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(232, 89, 12, 0.3);
        }

        .pricing-note {
            margin-top: 16px;
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        /* ── FINAL CTA ── */
        .final-section {
            padding: 100px 32px;
            background: var(--bg-dark);
            text-align: center;
        }

        .final-inner {
            max-width: 600px;
            margin: 0 auto;
        }

        .final-section h2 {
            font-size: clamp(1.6rem, 3vw, 2.2rem);
            font-weight: 800;
            color: #fff;
            letter-spacing: -1px;
            margin-bottom: 16px;
            line-height: 1.35;
            word-break: keep-all;
        }

        .final-section h2 em {
            font-style: normal;
            color: var(--accent);
        }

        .final-desc {
            font-size: 0.95rem;
            color: rgba(255,255,255,0.45);
            margin-bottom: 36px;
            line-height: 1.7;
        }

        .final-section .btn-pricing {
            background: #fff;
            color: var(--bg-dark);
        }

        .final-section .btn-pricing:hover {
            background: #F0EDE6;
            box-shadow: 0 8px 30px rgba(255,255,255,0.15);
        }

        .final-note {
            margin-top: 20px;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.3);
        }

        /* ── FOOTER ── */
        footer {
            padding: 40px 32px;
            border-top: 1px solid var(--border-light);
            text-align: center;
        }

        .footer-text {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ── ANIMATIONS ── */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 900px) {
            .hero-grid {
                grid-template-columns: 1fr;
                gap: 48px;
            }

            .hero-visual {
                order: -1;
            }

            .newsletter-preview {
                transform: none;
            }

            .ba-grid {
                grid-template-columns: 1fr;
                gap: 24px;
            }

            .ba-arrow {
                transform: rotate(90deg);
            }

            .how-steps {
                grid-template-columns: 1fr;
            }

            .persona-grid {
                grid-template-columns: 1fr;
            }

            .proof-grid {
                grid-template-columns: 1fr;
            }

            .hero-stats {
                gap: 20px;
            }
        }

        @media (max-width: 600px) {
            .hero {
                padding: 100px 20px 60px;
            }

            .hero h1 {
                font-size: 1.8rem;
            }

            .hero-stats {
                flex-wrap: wrap;
                gap: 16px;
            }

            .pricing-card {
                padding: 40px 24px;
            }
        }
    </style>
</head>
